<script>
  // Scroll reveal
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal, .stagger').forEach(el => obs.observe(el));

  // Segment tabs
  function showSeg(seg, btn) {
    document.querySelectorAll('.seg-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.seg-content').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('seg-' + seg).classList.add('active');
  }
</script>
</body>
