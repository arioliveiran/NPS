      <button onclick="switchCloud('premium',this)" class="cloud-tab" style="padding:11px 24px;font-size:13px;font-weight:700;cursor:pointer;color:rgba(255,255,255,0.5);background:transparent;border:none;font-family:'Nunito',sans-serif;">Premium/Assessor</button>
    </div>

    <!-- Cloud container -->
    <div class="reveal" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:20px;padding:48px;min-height:340px;display:flex;align-items:center;justify-content:center;">
      <div id="wordcloud-canvas" style="width:100%;line-height:1.6;text-align:center;"></div>
    </div>

    <!-- Legend -->
    <div class="reveal" style="display:flex;gap:24px;margin-top:20px;flex-wrap:wrap;">
      <div style="display:flex;align-items:center;gap:8px;"><div style="width:12px;height:12px;border-radius:3px;background:var(--teal);"></div><span style="font-size:12px;color:rgba(255,255,255,0.4);">Positivo / produto</span></div>
      <div style="display:flex;align-items:center;gap:8px;"><div style="width:12px;height:12px;border-radius:3px;background:var(--red);"></div><span style="font-size:12px;color:rgba(255,255,255,0.4);">Ponto de atenção</span></div>
      <div style="display:flex;align-items:center;gap:8px;"><div style="width:12px;height:12px;border-radius:3px;background:var(--amber);"></div><span style="font-size:12px;color:rgba(255,255,255,0.4);">Sugestão / melhoria</span></div>
      <div style="display:flex;align-items:center;gap:8px;"><div style="width:12px;height:12px;border-radius:3px;background:rgba(255,255,255,0.5);"></div><span style="font-size:12px;color:rgba(255,255,255,0.4);">Neutro</span></div>
    </div>
  </div>
</section>

<script>
// Word data per tab
const CLOUDS = {
  geral: [
    {w:"genial",n:21},{w:"plataforma",n:15},{w:"investimento",n:15},{w:"atendimento",n:12},
    {w:"investimentos",n:10},{w:"melhorar",n:10},{w:"conta",n:9},{w:"valor",n:9},
    {w:"suporte",n:7},{w:"cartão",n:7},{w:"informações",n:7},{w:"poderia",n:7},
    {w:"melhor",n:7},{w:"aplicativo",n:6},{w:"site",n:6},{w:"opções",n:6},
    {w:"falta",n:5},{w:"ações",n:5},{w:"débito",n:5},{w:"renda",n:5},
    {w:"empresa",n:5},{w:"investir",n:5},{w:"assessor",n:4},{w:"acesso",n:4},
    {w:"mercado",n:4},{w:"cliente",n:4},{w:"carteira",n:4},{w:"ruim",n:4},
    {w:"operar",n:4},{w:"contato",n:4},{w:"taxas",n:3},{w:"profit",n:3},
    {w:"parabéns",n:3},{w:"segurança",n:3},{w:"experiência",n:3},{w:"demora",n:3},
    {w:"assessoria",n:3},{w:"conteúdos",n:3},{w:"iniciantes",n:3},{w:"crédito",n:3},
    {w:"simples",n:3},{w:"confiança",n:3},{w:"corretora",n:2},{w:"dúvidas",n:2},
    {w:"resultados",n:2},{w:"operações",n:3},{w:"disponível",n:3},{w:"deveria",n:3},
  ],
  digital: [
    {w:"investimento",n:11},{w:"genial",n:8},{w:"investimentos",n:6},{w:"opções",n:5},
    {w:"plataforma",n:4},{w:"acessar",n:4},{w:"empresa",n:3},{w:"parabéns",n:3},
    {w:"investir",n:3},{w:"contato",n:3},{w:"ruim",n:3},{w:"informações",n:3},
    {w:"valor",n:3},{w:"melhorar",n:2},{w:"experiência",n:2},{w:"falta",n:2},
    {w:"cartão",n:2},{w:"atendimento",n:2},{w:"segurança",n:2},{w:"conta",n:2},
    {w:"carteira",n:2},{w:"assessoria",n:2},{w:"cliente",n:2},{w:"suporte",n:2},
  ],
  trader: [
    {w:"atendimento",n:9},{w:"genial",n:8},{w:"plataforma",n:7},{w:"conta",n:4},
    {w:"valor",n:4},{w:"aplicativo",n:4},{w:"poderia",n:4},{w:"anos",n:3},
    {w:"operações",n:3},{w:"profit",n:3},{w:"suporte",n:3},{w:"clientes",n:3},
    {w:"corretora",n:2},{w:"mercado",n:2},{w:"melhor",n:2},{w:"iniciantes",n:2},
    {w:"deveria",n:2},{w:"melhorar",n:2},{w:"acesso",n:2},{w:"taxas",n:2},
    {w:"site",n:2},{w:"traders",n:2},{w:"dividendos",n:2},{w:"cartão",n:2},
  ],
  premium: [
    {w:"genial",n:5},{w:"melhorar",n:5},{w:"ações",n:4},{w:"plataforma",n:4},
    {w:"investimentos",n:3},{w:"melhor",n:3},{w:"informações",n:3},{w:"conta",n:3},
    {w:"cartão",n:3},{w:"débito",n:3},{w:"operar",n:3},{w:"suporte",n:3},
    {w:"renda",n:3},{w:"investimento",n:3},{w:"assessor",n:2},{w:"investir",n:2},
    {w:"falta",n:2},{w:"site",n:2},{w:"demora",n:2},{w:"simples",n:2},
    {w:"crédito",n:2},{w:"disponível",n:2},{w:"valor",n:2},{w:"vencimento",n:2},
  ]
};

// Color mapping by sentiment
const COLORS = {
  // Positivo (teal/green)
  genial:'#00C2CB', investimento:'#00C2CB', investimentos:'#00C2CB', investir:'#00C2CB',
  melhor:'#00C48C', parabéns:'#00C48C', segurança:'#00C48C', confiança:'#00C48C',
  experiência:'#00C48C', simples:'#00C48C', empresa:'#00C2CB', corretora:'#00C2CB',
  conta:'#3B82F6', ações:'#3B82F6', renda:'#3B82F6', mercado:'#3B82F6',
  carteira:'#3B82F6', opções:'#3B82F6', operações:'#3B82F6', operar:'#3B82F6',
  informações:'#3B82F6', conteúdos:'#3B82F6', iniciantes:'#3B82F6', resultados:'#3B82F6',
  assessor:'#A855F7', assessoria:'#A855F7', atendimento:'#A855F7', cliente:'#A855F7',
  clientes:'#A855F7', contato:'#A855F7',
  // Atenção (red/amber)
  ruim:'#EF4444', demora:'#EF4444', falta:'#EF4444', suporte:'#F59E0B',
  acesso:'#F59E0B', acessar:'#F59E0B', taxas:'#F59E0B', profit:'#F59E0B',
  // Sugestão (amber)
  melhorar:'#F59E0B', poderia:'#F59E0B', deveria:'#F59E0B', disponível:'#F59E0B',
  // Produto (light)
  plataforma:'#E2E8F0', aplicativo:'#E2E8F0', site:'#E2E8F0', valor:'#E2E8F0',
  cartão:'#E2E8F0', débito:'#E2E8F0', crédito:'#E2E8F0', anos:'#E2E8F0',
  traders:'#E2E8F0', dividendos:'#E2E8F0', vencimento:'#E2E8F0',
};

function getColor(word) {
  return COLORS[word] || 'rgba(255,255,255,0.55)';
}

function getFontSize(n, max, min_px=13, max_px=72) {
  const scale = (n - 1) / (max - 1 + 0.001);
  return Math.round(min_px + scale * (max_px - min_px));
}

function renderCloud(key) {
  const words = CLOUDS[key];
  const max = words[0].n;
  const canvas = document.getElementById('wordcloud-canvas');
  
  // Sort randomly but weight by frequency
  const shuffled = [...words].sort(() => Math.random() - 0.45);
  
  canvas.innerHTML = shuffled.map(({w, n}) => {
    const size = getFontSize(n, max);
    const color = getColor(w);
    const weight = n >= max*0.6 ? 900 : n >= max*0.35 ? 800 : 700;
    const opacity = n >= max*0.3 ? 1 : 0.7 + (n/max)*0.3;
    const rotate = Math.random() > 0.85 ? (Math.random() > 0.5 ? 'rotate(-8deg)' : 'rotate(8deg)') : 'none';
    return `<span style="
      display:inline-block;
      font-family:'Nunito',sans-serif;
      font-size:${size}px;
      font-weight:${weight};
      color:${color};
      opacity:${opacity};
      margin:4px 8px;
      cursor:default;
      transform:${rotate};
      transition:all .2s;
      letter-spacing:-0.3px;
    " onmouseover="this.style.opacity=1;this.style.transform='scale(1.12)'"
       onmouseout="this.style.opacity='${opacity}';this.style.transform='${rotate}'"
       title="${n} menções">${w}</span>`;
  }).join('');
}

function switchCloud(key, btn) {
  document.querySelectorAll('.cloud-tab').forEach(t => {
    t.style.background = 'transparent';
    t.style.color = 'rgba(255,255,255,0.5)';
  });
  btn.style.background = 'var(--blue)';
  btn.style.color = 'white';
  renderCloud(key);
}

// Initial render
renderCloud('geral');
</script>

